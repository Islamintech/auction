# Server
PORT=3000
# Set to "production" on the deployment host to enable secure/SameSite=None cookies
NODE_ENV=production

# MongoDB connection string (MongoDB Atlas or self-hosted)
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>/<db>

# Secrets — generate strong random values, do NOT reuse these examples
SECRET_TOKEN=change-me-jwt-secret
SESSION_SECRET=change-me-session-secret

# Allowed browser origin(s) for CORS — comma-separated for multiple
# (e.g. the deployed React frontend + admin domain). Leave unset in dev.
CORS_ORIGIN=https://your-frontend-domain.com,https://admin.your-domain.com

# Cloudinary — image uploads (production). Either set CLOUDINARY_URL …
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
# … or the three discrete vars instead:
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret
# If none are set, uploads fall back to local disk (./uploads) for dev.
