<script>
  function toggleTheme() {
    var isDark = document.documentElement.classList.toggle('dark');
    var t = isDark ? 'dark' : 'light';
    document.documentElement.dataset.theme = t;
    try { localStorage.setItem('theme', t); } catch (e) {}
  }
</script>
<script type="text/javascript" src="/js/main.js"></script>

<!-- PWA install prompt: nudge mobile admins to add the app to their home screen -->
<div id="pwa-install-banner"
  style="display:none;position:fixed;left:12px;right:12px;bottom:12px;z-index:9999;
         background:rgb(var(--surface));color:rgb(var(--on-surface));
         border:1px solid rgb(var(--primary) / 0.35);border-radius:14px;
         box-shadow:0 12px 40px -8px rgba(0,0,0,0.5);padding:14px 16px;
         max-width:480px;margin:0 auto;font-family:'Plus Jakarta Sans',system-ui,sans-serif;">
  <div style="display:flex;align-items:center;gap:12px;">
    <img src="/img/logo.png" alt="" style="width:42px;height:42px;border-radius:10px;flex-shrink:0;" />
    <div style="flex:1;min-width:0;">
      <div style="font-weight:700;font-size:14px;">Install AutoAuction Admin</div>
      <div id="pwa-install-text" style="font-size:12px;opacity:0.7;margin-top:2px;line-height:1.4;">
        Add it to your home screen for quick, app-like access.
      </div>
    </div>
  </div>
  <div style="display:flex;gap:8px;margin-top:12px;justify-content:flex-end;">
    <button id="pwa-dismiss"
      style="padding:8px 14px;border-radius:9px;border:1px solid rgb(var(--outline) / 0.35);
             background:transparent;color:rgb(var(--on-surface) / 0.7);font-size:12px;font-weight:600;cursor:pointer;">
      Not now
    </button>
    <button id="pwa-install-btn"
      style="padding:8px 18px;border-radius:9px;border:none;background:rgb(var(--primary));
             color:rgb(var(--background));font-size:12px;font-weight:700;cursor:pointer;">
      Install
    </button>
  </div>
</div>

<script>
(function () {
  var DELAY_MS = 30000;          // show after 30 seconds
  var SNOOZE_MS = 7 * 24 * 3600 * 1000;  // re-ask at most weekly after dismissal
  var STORAGE_KEY = 'pwaInstallDismissedAt';

  // Skip if already installed / running as an installed app.
  var standalone = window.matchMedia('(display-mode: standalone)').matches
    || window.navigator.standalone === true;
  if (standalone) return;

  // Mobile only — desktop admins don't need a home-screen shortcut.
  var isMobile = /Android|iPhone|iPad|iPod/i.test(navigator.userAgent)
    || window.matchMedia('(max-width: 768px)').matches;
  if (!isMobile) return;

  // Respect a recent dismissal.
  try {
    var last = Number(localStorage.getItem(STORAGE_KEY) || 0);
    if (last && Date.now() - last < SNOOZE_MS) return;
  } catch (e) {}

  // Register the service worker (required for the Android install prompt).
  if ('serviceWorker' in navigator) {
    navigator.serviceWorker.register('/sw.js').catch(function () {});
  }

  var deferredPrompt = null;
  var isIOS = /iPhone|iPad|iPod/i.test(navigator.userAgent) && !window.MSStream;

  window.addEventListener('beforeinstallprompt', function (e) {
    e.preventDefault();          // stop Chrome's mini-infobar; we show our own
    deferredPrompt = e;
  });

  function dismiss() {
    var banner = document.getElementById('pwa-install-banner');
    if (banner) banner.style.display = 'none';
    try { localStorage.setItem(STORAGE_KEY, String(Date.now())); } catch (e) {}
  }

  function showBanner() {
    if (standalone) return;
    var banner = document.getElementById('pwa-install-banner');
    var installBtn = document.getElementById('pwa-install-btn');
    var text = document.getElementById('pwa-install-text');
    if (!banner) return;

    if (deferredPrompt) {
      // Android / Chrome: real install flow.
      installBtn.onclick = function () {
        deferredPrompt.prompt();
        deferredPrompt.userChoice.finally(function () {
          deferredPrompt = null;
          dismiss();
        });
      };
    } else if (isIOS) {
      // iOS Safari has no install API — show the manual gesture instead.
      text.innerHTML = 'Tap the Share icon, then choose <b>“Add to Home Screen”</b>.';
      installBtn.textContent = 'Got it';
      installBtn.onclick = dismiss;
    } else {
      // No install support and not iOS — nothing useful to offer.
      return;
    }

    banner.style.display = 'block';
  }

  document.getElementById('pwa-dismiss').addEventListener('click', dismiss);
  window.addEventListener('appinstalled', dismiss);

  setTimeout(showBanner, DELAY_MS);
})();
</script>
</body>
</html>
