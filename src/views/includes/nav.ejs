<header class="fixed top-0 w-full h-[60px] z-50 bg-[#121414]/80 backdrop-blur-xl border-b border-primary/20 flex justify-center px-6">
  <div class="w-full max-w-[1300px] flex justify-between items-center">

    <div class="nav-brand">
     <div class="w-8 h-8 rounded-full bg-white flex items-center justify-center overflow-hidden flex-shrink-0">
       <img src="/img/logo.jpg" alt="Auction.uz" class="w-full h-full object-cover" />
     </div>
    <span class="brand-name">AUCTION.UZ</span>
  </div>

    <nav class="hidden md:flex gap-8 text-[11px] uppercase tracking-[0.2em] font-mono">
      <a class="<%= page === 'home'          ? 'text-primary border-b border-primary pb-1' : 'text-on-surface-secondary hover:text-primary' %> transition-colors" href="/admin">Home</a>
      <a class="<%= page === 'cars'          ? 'text-primary border-b border-primary pb-1' : 'text-on-surface-secondary hover:text-primary' %> transition-colors" href="/admin/car/all">Cars</a>
      <a class="<%= page === 'members'       ? 'text-primary border-b border-primary pb-1' : 'text-on-surface-secondary hover:text-primary' %> transition-colors" href="/admin/member/all">Members</a>
      <a class="<%= page === 'consultations' ? 'text-primary border-b border-primary pb-1' : 'text-on-surface-secondary hover:text-primary' %> transition-colors" href="/admin/consultation/all">Consultations</a>
      <a class="<%= page === 'posts'         ? 'text-primary border-b border-primary pb-1' : 'text-on-surface-secondary hover:text-primary' %> transition-colors" href="/admin/post/all">Posts</a>
    </nav>

    <div class="flex items-center gap-4">
      <a href="/admin/logout" onclick="return confirm('Logout?')"
        class="text-on-surface-secondary hover:text-danger transition-colors font-mono text-[10px] uppercase tracking-widest">
        Logout
      </a>
      <div class="h-8 w-8 rounded-full bg-surface flex items-center justify-center border border-outline text-primary font-mono text-xs font-bold overflow-hidden">
        <% if(member && member.memberImage) { %>
          <img src="/<%= member.memberImage %>" class="w-full h-full object-cover" />
        <% } else if(member) { %>
          <%= member.memberNick?.charAt(0).toUpperCase() %>
        <% } %>
      </div>
    </div>

  </div>
</header>