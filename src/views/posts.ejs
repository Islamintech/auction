<%- include('includes/header') %>
<%- include('includes/nav', { page: 'posts' }) %>

<style>
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
  .type-article   { background: rgba(69,223,164,0.1); color: #34d399; border: 1px solid rgba(69,223,164,0.2); }
  .type-news      { background: rgba(251,191,36,0.1); color: #fbbf24; border: 1px solid rgba(251,191,36,0.2); }
  .type-freeboard { background: rgba(255,255,255,0.05); color: rgba(255,255,255,0.4); border: 1px solid rgba(255,255,255,0.1); }
  .filter-btn.active { border-color: rgba(251,191,36,0.4); color: #fbbf24; }
</style>

<body class="bg-background">
<main class="pt-[60px] min-h-screen">
  <div class="max-w-[1300px] mx-auto p-8">

    <!-- Page Header -->
    <div class="flex justify-between items-end mb-8">
      <div>
        <h1 class="text-2xl font-headline font-bold text-on-surface tracking-tight uppercase">Editorial Management</h1>
        <p class="text-on-surface-secondary text-xs font-mono mt-1 tracking-widest uppercase">Posts & Community Content</p>
      </div>
      <div class="flex gap-4 items-center">
        <div class="flex flex-col items-end">
          <span class="text-[10px] text-on-surface-faint uppercase font-mono">Total Posts</span>
          <span class="text-xl font-mono text-primary font-bold"><%= posts.length %></span>
        </div>
        <div class="w-px h-10 bg-outline mx-2"></div>
        <div class="flex flex-col items-end">
          <span class="text-[10px] text-on-surface-faint uppercase font-mono">Articles</span>
          <span class="text-xl font-mono text-success font-bold">
            <%= posts.filter(p => p.postType === 'ARTICLE').length %>
          </span>
        </div>
      </div>
    </div>

    <!-- Create Post Form -->
    <div class="mb-10 bg-surface rounded-card border border-outline overflow-hidden shadow-2xl">
      <details class="group">
        <summary class="list-none px-8 py-5 cursor-pointer flex justify-between items-center hover:bg-white/[0.02] transition-colors border-b border-outline">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center border border-primary/20">
              <span class="text-primary text-xl">+</span>
            </div>
            <div>
              <h3 class="font-headline text-sm font-bold text-on-surface uppercase tracking-widest">Create New Post</h3>
              <p class="text-[10px] text-on-surface-secondary uppercase tracking-wider mt-0.5 font-mono">Publish news, article or free board</p>
            </div>
          </div>
          <span class="text-primary text-xl group-open:rotate-180 transition-transform">▾</span>
        </summary>

        <div class="p-8">
          <form action="/admin/post/create" method="POST" enctype="multipart/form-data" class="flex flex-col gap-6">

            <div class="grid grid-cols-2 gap-6">
              <div class="col-span-2">
                <label class="block text-xs uppercase tracking-widest font-mono font-bold text-primary mb-2">Title *</label>
                <input name="postTitle" type="text" required
                  placeholder="e.g. New arrivals from Korea this week"
                  class="w-full bg-black/40 border border-outline rounded-lg focus:border-primary text-on-surface px-4 py-3 text-sm outline-none transition-all" />
              </div>
              <div>
                <label class="block text-xs uppercase tracking-widest font-mono font-bold text-primary mb-2">Type *</label>
                <select name="postType" required
                  class="w-full bg-black/40 border border-outline rounded-lg focus:border-primary text-on-surface px-4 py-3 text-sm outline-none"
                  style="appearance:none">
                  <option value="">Select type</option>
                  <option value="NEWS">News</option>
                  <option value="ARTICLE">Article</option>
                  <option value="FREE_BOARD">Free Board</option>
                </select>
              </div>
            </div>

            <div>
              <label class="block text-xs uppercase tracking-widest font-mono font-bold text-primary mb-2">Body *</label>
              <textarea name="postBody" rows="6" required
                placeholder="Write your post content here..."
                class="w-full bg-black/40 border border-outline rounded-lg focus:border-primary text-on-surface px-4 py-3 text-sm outline-none resize-none transition-all"></textarea>
            </div>

            <div>
              <label class="block text-xs uppercase tracking-widest font-mono font-bold text-primary mb-2">
                Cover Image <span class="text-on-surface-faint font-normal normal-case tracking-normal">— optional</span>
              </label>
              <div class="relative bg-black/40 border border-dashed border-outline rounded-lg p-6 flex items-center gap-6 hover:border-primary/40 transition-colors cursor-pointer">
                <div class="w-20 h-20 rounded-lg bg-white/5 border border-outline flex items-center justify-center flex-shrink-0 overflow-hidden">
                  <span class="text-on-surface-faint text-2xl" id="post-img-icon">📷</span>
                  <img id="post-img-preview" class="w-full h-full object-cover" style="display:none" />
                </div>
                <div>
                  <p class="text-sm text-on-surface-secondary mb-1">Click to upload cover image</p>
                  <p class="text-xs text-on-surface-faint">JPG, PNG, WEBP · Max 5MB</p>
                </div>
                <input type="file" name="postImage" accept="image/*"
                  class="absolute inset-0 opacity-0 cursor-pointer w-full h-full"
                  onchange="previewPostImage(this)" />
              </div>
            </div>

            <div class="flex gap-3 justify-end pt-2">
              <button type="button" onclick="this.closest('details').removeAttribute('open')"
                class="px-6 py-3 rounded-lg border border-outline text-on-surface-secondary font-mono text-xs uppercase font-bold hover:border-danger hover:text-danger transition-all">
                Discard
              </button>
              <button type="submit"
                class="px-10 py-3 rounded-lg bg-primary text-background font-mono text-xs uppercase font-bold hover:bg-primary/80 transition-all">
                Publish Post
              </button>
            </div>
          </form>
        </div>
      </details>
    </div>

    <!-- Table Card -->
    <div class="bg-surface rounded-card border border-outline overflow-hidden shadow-2xl">
      <div class="px-8 py-5 border-b border-outline flex flex-wrap justify-between items-center gap-4 bg-white/[0.01]">
        <div class="flex items-center gap-4">
          <div class="flex items-center gap-3">
            <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
            <h3 class="font-headline text-xs font-bold tracking-[0.2em] uppercase text-on-surface">All Posts</h3>
          </div>
          <div class="flex gap-2">
            <button onclick="filterByType('all')" id="filter-all"
              class="filter-btn active px-3 py-1.5 rounded-full text-[10px] font-mono font-bold uppercase tracking-wider border border-outline text-on-surface-faint transition-all">
              All
            </button>
            <button onclick="filterByType('news')" id="filter-news"
              class="filter-btn px-3 py-1.5 rounded-full text-[10px] font-mono font-bold uppercase tracking-wider border border-outline text-on-surface-faint hover:border-primary/40 hover:text-primary transition-all">
              News
            </button>
            <button onclick="filterByType('article')" id="filter-article"
              class="filter-btn px-3 py-1.5 rounded-full text-[10px] font-mono font-bold uppercase tracking-wider border border-outline text-on-surface-faint hover:border-primary/40 hover:text-primary transition-all">
              Article
            </button>
            <button onclick="filterByType('free_board')" id="filter-free_board"
              class="filter-btn px-3 py-1.5 rounded-full text-[10px] font-mono font-bold uppercase tracking-wider border border-outline text-on-surface-faint hover:border-primary/40 hover:text-primary transition-all">
              Free Board
            </button>
          </div>
        </div>
        <input id="search-input" oninput="applyFilters()"
          class="bg-black/40 border border-outline rounded-full pl-4 pr-4 py-1.5 text-xs text-on-surface focus:border-primary w-48 font-mono outline-none"
          placeholder="Search title..." type="text" />
      </div>

      <div class="overflow-x-auto scrollbar-hide">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-black/20">
              <th class="px-8 py-4 text-[11px] uppercase tracking-[0.08em] font-mono font-bold text-on-surface-faint">#</th>
              <th class="px-4 py-4 text-[11px] uppercase tracking-[0.08em] font-mono font-bold text-on-surface-faint">Title</th>
              <th class="px-4 py-4 text-[11px] uppercase tracking-[0.08em] font-mono font-bold text-on-surface-faint">Type</th>
              <th class="px-4 py-4 text-[11px] uppercase tracking-[0.08em] font-mono font-bold text-on-surface-faint">Views</th>
              <th class="px-4 py-4 text-[11px] uppercase tracking-[0.08em] font-mono font-bold text-on-surface-faint">Engagement</th>
              <th class="px-4 py-4 text-[11px] uppercase tracking-[0.08em] font-mono font-bold text-on-surface-faint">Date</th>
              <th class="px-8 py-4 text-[11px] uppercase tracking-[0.08em] font-mono font-bold text-on-surface-faint text-right">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-outline" id="posts-tbody">
            <% posts.map(function(p, i) { %>
            <tr class="hover:bg-white/[0.03] transition-colors group post-row"
              data-title="<%= p.postTitle?.toLowerCase() %>"
              data-type="<%= p.postType?.toLowerCase() %>"
            >
              <td class="px-8 py-5 font-mono text-on-surface-faint text-xs"><%= String(i+1).padStart(2,'0') %></td>
              <td class="px-4 py-5">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-lg overflow-hidden flex-shrink-0 bg-white/5 border border-outline flex items-center justify-center">
                    <% if(p.postImage) { %>
                      <img src="/<%= p.postImage %>" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
                    <% } else { %>
                      <span class="text-on-surface-faint text-sm">📄</span>
                    <% } %>
                  </div>
                  <div class="font-bold text-base text-on-surface truncate max-w-[280px]"><%= p.postTitle %></div>
                </div>
              </td>
              <td class="px-4 py-5">
                <span class="px-2 py-1 rounded-full text-[9px] font-bold tracking-wider
                  <%= p.postType === 'ARTICLE' ? 'type-article' : p.postType === 'NEWS' ? 'type-news' : 'type-freeboard' %>">
                  <%= p.postType %>
                </span>
              </td>
              <td class="px-4 py-5 font-mono text-sm text-on-surface-secondary">
                <%= p.postViewCount?.toLocaleString() || 0 %>
              </td>
              <td class="px-4 py-5">
                <div class="flex items-center gap-3 text-on-surface-faint text-xs">
                  <span>❤️ <%= p.postLikeCount || 0 %></span>
                  <span>💬 <%= p.postCommentCount || 0 %></span>
                </div>
              </td>
              <td class="px-4 py-5 text-sm text-on-surface-secondary">
                <%= new Date(p.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %>
              </td>
              <td class="px-8 py-5 text-right">
                <button onclick="deletePost('<%= p._id %>')"
                  class="p-2 rounded hover:bg-white/10 text-on-surface-secondary hover:text-danger transition-colors" title="Delete">
                  🗑
                </button>
              </td>
            </tr>
            <% }) %>
            <% if(posts.length === 0) { %>
            <tr>
              <td colspan="7" class="px-8 py-16 text-center text-on-surface-faint font-mono text-xs uppercase tracking-widest">
                No posts yet. Create your first post above.
              </td>
            </tr>
            <% } %>
          </tbody>
        </table>
      </div>

      <div class="px-8 py-5 bg-white/[0.01] border-t border-outline flex justify-between items-center">
        <span class="text-[10px] uppercase tracking-widest font-mono font-bold text-on-surface-faint">
          <%= posts.length %> Total Posts
        </span>
      </div>
    </div>

  </div>
</main>


<script>
let activeType = 'all';

function filterByType(type) {
    activeType = type;
    document.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
    document.getElementById('filter-' + type)?.classList.add('active');
    applyFilters();
}

function applyFilters() {
    const query = document.getElementById('search-input').value.toLowerCase();
    document.querySelectorAll('.post-row').forEach(row => {
        const title = row.dataset.title || '';
        const type  = row.dataset.type  || '';
        const matchesSearch = title.includes(query);
        const matchesType   = activeType === 'all' || type === activeType;
        row.style.display = (matchesSearch && matchesType) ? '' : 'none';
    });
}

function previewPostImage(input) {
    if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = (e) => {
            const preview = document.getElementById('post-img-preview');
            const icon    = document.getElementById('post-img-icon');
            preview.src = e.target.result;
            preview.style.display = 'block';
            icon.style.display = 'none';
        };
        reader.readAsDataURL(input.files[0]);
    }
}

function deletePost(id) {
    if (!confirm('Delete this post?')) return;
    fetch(`/admin/post/${id}/delete`, { method: 'POST' })
        .then(() => window.location.reload())
        .catch(() => alert('Failed to delete'));
}
</script>

</body>
<%- include('includes/footer') %>