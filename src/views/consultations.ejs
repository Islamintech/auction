<%- include('includes/header') %>
<%- include('includes/nav', { page: 'consultations' }) %>

<style>
  .status-pending    { background: rgba(251,191,36,0.1); color: #fbbf24; border: 1px solid rgba(251,191,36,0.2); }
  .status-inprogress { background: rgba(56,189,248,0.1); color: #38bdf8; border: 1px solid rgba(56,189,248,0.2); }
  .status-resolved   { background: rgba(52,211,153,0.1); color: #34d399; border: 1px solid rgba(52,211,153,0.2); }
  .status-cancelled  { background: rgba(248,113,113,0.1); color: #f87171; border: 1px solid rgba(248,113,113,0.2); }
  .channel-telegram  { background: rgba(0,136,204,0.1); color: #0088cc; }
  .channel-whatsapp  { background: rgba(37,211,102,0.1); color: #25d366; }
  .channel-phone     { background: rgba(52,211,153,0.1); color: #34d399; }
  .channel-email     { background: rgba(251,191,36,0.1); color: #fbbf24; }
  .filter-btn.active { border-color: rgba(251,191,36,0.4); color: #fbbf24; }
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<body class="bg-background">
<main class="pt-[60px] min-h-screen">
  <div class="max-w-[1300px] mx-auto p-8">

    <!-- Page Header -->
    <div class="flex justify-between items-end mb-8">
      <div>
        <h1 class="text-2xl font-headline font-bold text-on-surface tracking-tight uppercase">Consultation Vault</h1>
        <p class="text-on-surface-secondary text-xs font-mono mt-1 tracking-widest uppercase">Buyer Requests & Follow-ups</p>
      </div>
      <div class="flex gap-4 items-center">
        <div class="flex flex-col items-end">
          <span class="text-[10px] text-on-surface-faint uppercase font-mono">Total</span>
          <span class="text-xl font-mono text-primary font-bold"><%= consultations.length %></span>
        </div>
        <div class="w-px h-10 bg-outline mx-2"></div>
        <div class="flex flex-col items-end">
          <span class="text-[10px] text-on-surface-faint uppercase font-mono">Pending</span>
          <span class="text-xl font-mono font-bold" style="color:#fbbf24">
            <%= consultations.filter(c => c.status === 'PENDING').length %>
          </span>
        </div>
      </div>
    </div>

    <!-- Table Card -->
    <div class="bg-surface rounded-card border border-outline overflow-hidden shadow-2xl">

      <div class="px-8 py-5 border-b border-outline flex flex-wrap justify-between items-center gap-4 bg-white/[0.01]">
        <div class="flex items-center gap-4">
          <div class="flex items-center gap-3">
            <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
            <h3 class="font-headline text-xs font-bold tracking-[0.2em] uppercase text-on-surface">All Requests</h3>
          </div>
          <div class="flex gap-2">
            <button onclick="filterByStatus('all')" id="filter-all"
              class="filter-btn active px-3 py-1.5 rounded-full text-[10px] font-mono font-bold uppercase tracking-wider border border-outline text-on-surface-faint transition-all">
              All
            </button>
            <button onclick="filterByStatus('PENDING')" id="filter-PENDING"
              class="filter-btn px-3 py-1.5 rounded-full text-[10px] font-mono font-bold uppercase tracking-wider border border-outline text-on-surface-faint hover:border-primary/40 hover:text-primary transition-all">
              Pending
            </button>
            <button onclick="filterByStatus('IN_PROGRESS')" id="filter-IN_PROGRESS"
              class="filter-btn px-3 py-1.5 rounded-full text-[10px] font-mono font-bold uppercase tracking-wider border border-outline text-on-surface-faint hover:border-primary/40 hover:text-primary transition-all">
              In Progress
            </button>
            <button onclick="filterByStatus('RESOLVED')" id="filter-RESOLVED"
              class="filter-btn px-3 py-1.5 rounded-full text-[10px] font-mono font-bold uppercase tracking-wider border border-outline text-on-surface-faint hover:border-primary/40 hover:text-primary transition-all">
              Resolved
            </button>
            <button onclick="filterByStatus('CANCELLED')" id="filter-CANCELLED"
              class="filter-btn px-3 py-1.5 rounded-full text-[10px] font-mono font-bold uppercase tracking-wider border border-outline text-on-surface-faint hover:border-primary/40 hover:text-primary transition-all">
              Cancelled
            </button>
          </div>
        </div>
        <input
          id="search-input"
          oninput="applyFilters()"
          class="bg-black/40 border border-outline rounded-full pl-4 pr-4 py-1.5 text-xs text-on-surface focus:border-primary w-48 font-mono outline-none"
          placeholder="Search by name..."
          type="text"
        />
      </div>

      <div class="overflow-x-auto scrollbar-hide">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-black/20">
              <th class="px-8 py-4 text-[11px] uppercase tracking-[0.08em] font-mono font-bold text-on-surface-faint">#</th>
              <th class="px-4 py-4 text-[11px] uppercase tracking-[0.08em] font-mono font-bold text-on-surface-faint">Car</th>
              <th class="px-4 py-4 text-[11px] uppercase tracking-[0.08em] font-mono font-bold text-on-surface-faint">Customer</th>
              <th class="px-4 py-4 text-[11px] uppercase tracking-[0.08em] font-mono font-bold text-on-surface-faint">Channel</th>
              <th class="px-4 py-4 text-[11px] uppercase tracking-[0.08em] font-mono font-bold text-on-surface-faint">Message</th>
              <th class="px-4 py-4 text-[11px] uppercase tracking-[0.08em] font-mono font-bold text-on-surface-faint">Status</th>
              <th class="px-8 py-4 text-[11px] uppercase tracking-[0.08em] font-mono font-bold text-on-surface-faint text-right">Date</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-outline" id="consultations-tbody">
            <% consultations.map(function(c, i) { %>
            <tr class="hover:bg-white/[0.03] transition-colors group consultation-row"
              data-name="<%= c.name?.toLowerCase() %>"
              data-status="<%= c.status %>"
            >
              <td class="px-8 py-5 font-mono text-on-surface-faint text-xs"><%= String(i+1).padStart(2,'0') %></td>
              <td class="px-4 py-5">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-lg overflow-hidden flex-shrink-0 bg-white/5 border border-outline flex items-center justify-center text-lg">🚗</div>
                  <div class="font-bold text-sm text-on-surface truncate max-w-[160px]">
                    <%= c.carId?.carTitle || '—' %>
                  </div>
                </div>
              </td>
              <td class="px-4 py-5">
                <div class="font-bold text-sm text-on-surface"><%= c.name %></div>
                <div class="text-xs text-on-surface-faint mt-0.5"><%= c.phone %></div>
              </td>
              <td class="px-4 py-5">
                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-bold uppercase
                  <%= c.preferredContact === 'TELEGRAM' ? 'channel-telegram' :
                      c.preferredContact === 'WHATSAPP' ? 'channel-whatsapp' :
                      c.preferredContact === 'CALL'     ? 'channel-phone' : 'channel-email' %>">
                  <span class="w-1.5 h-1.5 rounded-full bg-current"></span>
                  <%= c.preferredContact %>
                </span>
              </td>
              <td class="px-4 py-5">
                <p class="text-xs text-on-surface-secondary max-w-[200px] truncate"><%= c.message || '—' %></p>
              </td>
              <td class="px-4 py-5">
                <select
                  id="<%= c._id %>"
                  onchange="updateStatus(this)"
                  class="border-none text-[10px] font-bold uppercase px-3 py-1.5 rounded-lg cursor-pointer outline-none
                    <%= c.status === 'PENDING'     ? 'status-pending'    :
                        c.status === 'IN_PROGRESS' ? 'status-inprogress' :
                        c.status === 'RESOLVED'    ? 'status-resolved'   : 'status-cancelled' %>"
                >
                  <option value="PENDING"     <%= c.status === 'PENDING'     ? 'selected' : '' %>>Pending</option>
                  <option value="IN_PROGRESS" <%= c.status === 'IN_PROGRESS' ? 'selected' : '' %>>In Progress</option>
                  <option value="RESOLVED"    <%= c.status === 'RESOLVED'    ? 'selected' : '' %>>Resolved</option>
                  <option value="CANCELLED"   <%= c.status === 'CANCELLED'   ? 'selected' : '' %>>Cancelled</option>
                </select>
              </td>
              <td class="px-8 py-5 text-right text-sm text-on-surface-secondary">
                <%= new Date(c.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %>
              </td>
            </tr>
            <% }) %>
            <% if(consultations.length === 0) { %>
            <tr>
              <td colspan="7" class="px-8 py-16 text-center text-on-surface-faint font-mono text-xs uppercase tracking-widest">
                No consultation requests yet.
              </td>
            </tr>
            <% } %>
          </tbody>
        </table>
      </div>

      <div class="px-8 py-5 bg-white/[0.01] border-t border-outline flex justify-between items-center">
        <span class="text-[10px] uppercase tracking-widest font-mono font-bold text-on-surface-faint">
          <%= consultations.length %> Total Requests
        </span>
      </div>
    </div>

  </div>
</main>


<script>
let activeStatus = 'all';

function filterByStatus(status) {
    activeStatus = status;
    document.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
    document.getElementById('filter-' + status)?.classList.add('active');
    applyFilters();
}

function applyFilters() {
    const query = document.getElementById('search-input').value.toLowerCase();
    document.querySelectorAll('.consultation-row').forEach(row => {
        const name   = row.dataset.name   || '';
        const status = row.dataset.status || '';
        const matchesSearch = name.includes(query);
        const matchesStatus = activeStatus === 'all' || status === activeStatus;
        row.style.display = (matchesSearch && matchesStatus) ? '' : 'none';
    });
}

function updateStatus(select) {
    const id     = select.id;
    const status = select.value;
    select.className = select.className.replace(/status-\w+/g, '');
    const cls = status === 'PENDING'     ? 'status-pending'    :
                status === 'IN_PROGRESS' ? 'status-inprogress' :
                status === 'RESOLVED'    ? 'status-resolved'   : 'status-cancelled';
    select.classList.add(cls);
    select.closest('tr').dataset.status = status;
    fetch(`/admin/consultation/${id}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status }),
    })
    .then(() => console.log('Status updated'))
    .catch(() => alert('Failed to update status'));
}
</script>

</body>
<%- include('includes/footer') %>