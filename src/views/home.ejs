<%- include('includes/header') %>
<%- include('includes/nav', { page: 'home' }) %>
<link rel="stylesheet" type="text/css" href="/css/home.css" />

<body>
  <div class="home-container">

    <% if(!member) { %>

    <!-- Guest Hero -->
    <div class="hero-guest">
      <div class="car-animation-wrapper">
        <div class="car-scene">
          <div class="road">
            <div class="road-line"></div>
            <div class="road-line"></div>
            <div class="road-line"></div>
          </div>
          <div class="car">
            <div class="car-body">
              <div class="car-top"></div>
              <div class="car-bottom"></div>
              <div class="car-window car-window--front"></div>
              <div class="car-window car-window--rear"></div>
              <div class="headlight headlight--front"></div>
              <div class="headlight headlight--rear"></div>
              <div class="light-beam"></div>
            </div>
            <div class="wheel wheel--front"><div class="wheel-inner"></div></div>
            <div class="wheel wheel--rear"><div class="wheel-inner"></div></div>
          </div>
          <div class="speed-lines">
            <div class="speed-line"></div>
            <div class="speed-line"></div>
            <div class="speed-line"></div>
            <div class="speed-line"></div>
            <div class="speed-line"></div>
          </div>
        </div>
      </div>
      <h1 class="vault-title"><span>AUCTION</span><em>.UZ</em></h1>
      <p class="vault-sub">ADMIN MANAGEMENT INTERFACE &nbsp;•&nbsp; V1.0.0</p>
      <div class="guest-actions">
        <a href="/admin/login" class="btn btn--primary">Login to Dashboard</a>
        <a href="/admin/signup" class="btn btn--ghost">Create Account</a>
      </div>
    </div>

    <% } else { %>

    <!-- Dashboard -->
    <div class="dashboard">

      <div class="dash-hero">
        <div class="car-animation-wrapper">
          <div class="car-scene">
            <div class="road">
              <div class="road-line"></div>
              <div class="road-line"></div>
              <div class="road-line"></div>
            </div>
            <div class="car">
              <div class="car-body">
                <div class="car-top"></div>
                <div class="car-bottom"></div>
                <div class="car-window car-window--front"></div>
                <div class="car-window car-window--rear"></div>
                <div class="headlight headlight--front"></div>
                <div class="headlight headlight--rear"></div>
                <div class="light-beam"></div>
              </div>
              <div class="wheel wheel--front"><div class="wheel-inner"></div></div>
              <div class="wheel wheel--rear"><div class="wheel-inner"></div></div>
            </div>
            <div class="speed-lines">
              <div class="speed-line"></div>
              <div class="speed-line"></div>
              <div class="speed-line"></div>
              <div class="speed-line"></div>
              <div class="speed-line"></div>
            </div>
          </div>
        </div>
        <h1 class="vault-title"><span>AUCTION</span><em>.UZ</em></h1>
        <p class="vault-sub">ADMIN MANAGEMENT INTERFACE &nbsp;•&nbsp; V1.0.0</p>
      </div>

      <!-- Stat Cards -->
      <div class="stat-cards">
        <a href="/admin/car/all" class="stat-card">
          <div class="stat-card-top">
            <div class="stat-card-icon">🚗</div>
            <div class="stat-card-label">LIVE INVENTORY</div>
          </div>
          <div class="stat-card-value"><%= stats ? stats.cars : '—' %></div>
          <div class="stat-card-sub">↗ total cars</div>
        </a>
        <a href="/admin/member/all" class="stat-card">
          <div class="stat-card-top">
            <div class="stat-card-icon">👤</div>
            <div class="stat-card-label">ACTIVE MEMBERS</div>
          </div>
          <div class="stat-card-value"><%= stats ? stats.members : '—' %></div>
          <div class="stat-card-sub">↗ registered users</div>
        </a>
        <a href="/admin/consultation/all" class="stat-card">
          <div class="stat-card-top">
            <div class="stat-card-icon">💬</div>
            <div class="stat-card-label">CONSULTATIONS</div>
          </div>
          <div class="stat-card-value"><%= stats ? stats.consultations : '—' %></div>
          <div class="stat-card-sub">● <%= stats ? stats.pending : 0 %> pending</div>
        </a>
        <a href="/admin/post/all" class="stat-card">
          <div class="stat-card-top">
            <div class="stat-card-icon">📝</div>
            <div class="stat-card-label">EDITORIAL POSTS</div>
          </div>
          <div class="stat-card-value"><%= stats ? stats.posts : '—' %></div>
          <div class="stat-card-sub">↗ active posts</div>
        </a>
      </div>

      <!-- Bottom panels -->
      <div class="dash-bottom">

        <div class="dash-panel dash-chart">
          <div class="panel-header">
            <div>
              <h2 class="panel-title">Bidding Velocity</h2>
              <p class="panel-sub">REAL-TIME ENGAGEMENT TRACKING</p>
            </div>
            <div class="chart-tabs">
              <button class="chart-tab active" id="tab-live">LIVE</button>
              <button class="chart-tab" id="tab-week">WEEK</button>
            </div>
          </div>
          <div class="bar-chart" id="bar-chart">
            <div class="bar" style="height:45%"></div>
            <div class="bar" style="height:60%"></div>
            <div class="bar" style="height:35%"></div>
            <div class="bar" style="height:75%"></div>
            <div class="bar" style="height:50%"></div>
            <div class="bar" style="height:40%"></div>
            <div class="bar" style="height:90%"></div>
            <div class="bar" style="height:55%"></div>
            <div class="bar" style="height:65%"></div>
            <div class="bar" style="height:80%"></div>
            <div class="bar" style="height:45%"></div>
            <div class="bar" style="height:70%"></div>
          </div>
        </div>

        <div class="dash-panel dash-logs">
          <div class="panel-header">
            <h2 class="panel-title">SYSTEM LOGS</h2>
          </div>
          <div class="log-list">
            <div class="log-item">
              <span class="log-dot log-dot--gold"></span>
              <div class="log-content">
                <p class="log-text">New consultation request received</p>
                <span class="log-time">2 MINUTES AGO</span>
              </div>
            </div>
            <div class="log-item">
              <span class="log-dot log-dot--gold"></span>
              <div class="log-content">
                <p class="log-text">New member registered</p>
                <span class="log-time">14 MINUTES AGO</span>
              </div>
            </div>
            <div class="log-item">
              <span class="log-dot log-dot--dim"></span>
              <div class="log-content">
                <p class="log-text">Car status updated to SOLD</p>
                <span class="log-time">1 HOUR AGO</span>
              </div>
            </div>
            <div class="log-item">
              <span class="log-dot log-dot--dim"></span>
              <div class="log-content">
                <p class="log-text">New post published</p>
                <span class="log-time">3 HOURS AGO</span>
              </div>
            </div>
          </div>
          <a href="/admin/consultation/all" class="logs-btn">VIEW CONSULTATIONS</a>
        </div>

      </div>
    </div>
    <% } %>
  </div>

  <script type="text/javascript" src="/js/home.js"></script>
</body>

<%- include('includes/footer') %>